# DIRECTUS - Ejemplo de configuración
# Copia este archivo a .env.directus.local y ajusta según necesites

# ============================================
# POSTGRESQL DATABASE
# ============================================
DB_CLIENT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=directus
DB_USER=directus
DB_PASSWORD=directus_secure_password_123

# ============================================
# DIRECTUS ADMIN (desde .env principal)
# ============================================
ADMIN_EMAIL=admin@pure24nutrition.cl
ADMIN_PASSWORD=TuContraseña123!@#

# ============================================
# SECURITY KEYS (CAMBIAR EN PRODUCCIÓN)
# ============================================
# Generar valores aleatorios seguros:
# Linux/Mac: openssl rand -hex 32
# Windows PowerShell: [Convert]::ToHexString((Get-Random -Count 32 -InputObject (0..255)))

KEY=change-me-in-production-random-32-char-string
SECRET=change-me-in-production-random-32-char-string

# ============================================
# PUBLIC URL
# ============================================
PUBLIC_URL=http://localhost:8055

# ============================================
# CORS (para desarrollo)
# ============================================
API_CORS_ENABLED=true
API_CORS_ORIGIN=*

# ============================================
# FILE STORAGE
# ============================================
STORAGE_LOCATIONS=local
STORAGE_LOCAL_DRIVER=local
STORAGE_LOCAL_ROOT=/directus/uploads

# ============================================
# AUTHENTICATION
# ============================================
AUTH_LOGIN_ATTEMPTS=5
AUTH_LOGIN_ATTEMPTS_WINDOW=15m

# ============================================
# EXTENSION
# ============================================
# Para activar custom endpoints, hooks, etc.
EXTENSIONS_LOCATION=/directus/extensions
