---
// src/components/ComparisonTable.astro
// Tabla de comparativa técnica: Pure24 vs Competidores
// Propósito: GEO - datos únicos y comparativas para AI engines

interface Product {
  name: string;
  isPure24: boolean;
}

interface ComparisonRow {
  feature: string;
  pure24: string;
  competitorA: string;
  competitorB: string;
  winner?: 'pure24' | 'competitorA' | 'competitorB';
}

interface Props {
  category?: 'recovery' | 'hydration' | 'immunity';
}

const { category = 'recovery' } = Astro.props;

// Datos de comparación por categoría
const comparisonData = {
  recovery: {
