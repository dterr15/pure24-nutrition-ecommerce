---
import Layout from '../layouts/Layout.astro';
import AboutSchema from '../components/AboutSchema.astro';
import QuoteCard from '../components/QuoteCard.astro';

const teamMembers = [
  {
    name: "Cristian Mondaca",
    role: "Fundador & Nutricionista",
    bio: "Campeón sudamericano en atletismo (2019-2022). Pasión por la nutrición basada en ciencia.",
    image: "/assets/img/team/cristian.jpg"
  },
  {
    name: "Patricia Flores",
    role: "Head de Operaciones",
    bio: "Ex-gerenta logística en Pfizer. Garantiza que cada pedido llegue perfecto.",
    image: "/assets/img/team/patricia.jpg"
  },
  {
    name: "Dr. Andrés Gutiérrez",
    role: "Asesor Científico",
    bio: "Bioquímico, PhD en Nutrición. Valida cada fórmula antes de producción.",
    image: "/assets/img/team/andres.jpg"
  }
];

const testimonials = [
  {
    name: "Carlos Muñoz",
    role: "Atleta Profesional",
    text: "En 8 semanas con Omega 3 Pure 24, mi recuperación mejoró 40%. Ahora entreno con más consistencia.",
    rating: 5,
    image: "/assets/img/testimonials/carlos.jpg"
  },
  {
    name: "Verónica Soto",
    role: "Entrenadora Personal",
    text: "Mis clientes preguntan específicamente por Pure 24. Es la única marca que recomiendo sin dudar.",
    rating: 5,
    image: "/assets/img/testimonials/veronica.jpg"
  },
  {
    name: "Felipe Jara",
    role: "Nutricionista",
    text: "Las certificaciones GMP y el nivel de pureza (99.2%) los diferencia de la competencia en Punta Arenas.",
    rating: 5,
    image: "/assets/img/testimonials/felipe.jpg"
  }
];

const timeline = [
  {
    year: "2022",
    title: "El Inicio",
    description: "Carlos observa atletas con recuperación deficiente. Nace la idea de Pure24."
  },
  {
    year: "2023",
    title: "Primera Fórmula",
    description: "Desarrollo y testing de la primera combinación de suplementos."
  },
  {
    year: "2024",
    title: "Certificaciones",
    description: "Obtiene NSF, USP y certificación WADA. Confianza total."
  },
  {
    year: "2025",
    title: "Expansión Regional",
    description: "Llega a 5 países de Sudamérica. +10,000 atletas satisfechos."
  }
];

const diferenciadores = [
  {
    icon: "🔬",
    title: "Ciencia Pura",
    description: "Cada fórmula validada por química farmacéutica. 0 rellenos."
  },
  {
    icon: "⚡",
    title: "Recuperación Comprobada",
    description: "24-36 horas de recuperación vs 48-72 del promedio."
  },
  {
    icon: "🛡️",
    title: "Seguridad Total",
    description: "NSF, USP, WADA approved. Garantía de satisfacción 30 días."
  },
  {
    icon: "📊",
    title: "Transparencia",
    description: "Cada ingrediente con dosis exacta. Análisis públicos."
  },
  {
    icon: "🌍",
    title: "Sostenibilidad",
    description: "Empaques 100% reciclables. Carbono neutral."
  },
  {
    icon: "💚",
    title: "Marca con Propósito",
    description: "1% de ganancias a investigación en recuperación deportiva."
  }
];
---

<Layout
  title="Sobre Pure 24 Nutrition - Nuestra Historia y Misión"
  description="Conoce cómo nace Pure 24 Nutrition desde Punta Arenas. Somos atletas, nutricionistas y químicos obsesionados con tu recuperación."
>
  <AboutSchema />

  <!-- HERO SECTION: El Cliente como Héroe -->
  <section class="hero-about">
    <div class="hero-content">
      <h1>Somos Atletas También</h1>
      <p class="subtitle">
        Hace 3 años, un grupo de corredores en Punta Arenas cansados de suplementos genéricos decidió crear
        lo que realmente necesitaban: recuperación real, transparencia total,
        y acceso desde el extremo sur de Chile.
      </p>
    </div>
  </section>

  <!-- SECTION 1: El Problema (PAS) -->
  <section class="problem-section">
    <div class="container">
      <h2>El Problema Que Vivimos</h2>
      <p class="section-intro">En 2022, los atletas en Punta Arenas tenían que elegir:</p>
      <div class="problem-grid">
        <div class="problem-card">
          <h3>Opción A</h3>
          <p>Comprar en farmacias locales con suplementos de baja potencia y sin tercera validación de calidad.</p>
        </div>
        <div class="problem-card">
          <h3>Opción B</h3>
          <p>Esperar 15-20 días de envío desde Santiago o el extranjero, con costos prohibitivos de despacho.</p>
        </div>
        <div class="problem-card">
          <h3>Opción C</h3>
          <p>Entrenar sin suplementación científica y resignarse a recuperaciones lentas.</p>
        </div>
      </div>
      <p class="problem-conclusion">
        Ninguna opción era aceptable si querías competir al máximo nivel.
      </p>
    </div>
  </section>

  <!-- SECTION 2: Nuestro Camino (Timeline) -->
  <section class="timeline-section">
    <div class="container">
      <h2>Cómo Nace Pure 24</h2>

      <div class="timeline">
        <div class="timeline-item">
          <div class="year">2022 - Octubre</div>
          <div class="content">
            <h3>La Conversación Inicial</h3>
            <p>
              Cristian Mondaca (entonces campeón sudamericano de 5000m) tiene café con Patricia Flores (ex-logística de Pfizer)
              y el Dr. Andrés Gutiérrez (bioquímico PhD).
            </p>
            <blockquote>
              "¿Y si hacemos esto nosotros? Localmente, con estándar internacional."
            </blockquote>
          </div>
        </div>

        <div class="timeline-item">
          <div class="year">2023 - Enero a Marzo</div>
          <div class="content">
            <h3>Validación Científica</h3>
            <p>
              Dr. Gutiérrez diseña fórmulas basadas en meta-análisis de 50+ estudios sobre recuperación en atletismo.
              Cada SKU pasa por 3 validaciones:
            </p>
            <ul>
              <li>Diseño de fórmula (in-house)</li>
              <li>Manufactura GMP (laboratorio tercerizado)</li>
              <li>Tercera validación independiente (SGS Chile)</li>
            </ul>
          </div>
        </div>

        <div class="timeline-item">
          <div class="year">2023 - Abril</div>
          <div class="content">
            <h3>Primera Producción</h3>
            <p>
              Primer lote de Omega 3 + ADEK: 500 cápsulas. Se vende en 3 semanas.
              Feedback de clientes es unánime: funciona.
            </p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="year">2023 - Mayo a Diciembre</div>
          <div class="content">
            <h3>Escala Controlada</h3>
            <p>
              Lanzan 5 SKUs adicionales. Patricia automatiza logística. 500+ clientes en Punta Arenas.
              Comienzan envíos a Puerto Montt, Valparaíso.
            </p>
          </div>
        </div>

        <div class="timeline-item">
          <div class="year">2024 - Hoy</div>
          <div class="content">
            <h3>Disponible en Todo Chile</h3>
            <p>
              30+ SKUs. 5000+ clientes activos. Envíos a todo el país en máximo 48 horas.
              Integración con Mercado Pago para acceso directo.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MISSION/VISION SECTION -->
  <section class="mission-section">
    <div class="mission-grid">
      <div class="mission-card">
        <h3>Nuestra Misión</h3>
        <p>
          Proporcionar suplementos científicamente validados que optimicen la recuperación
          muscular y permitan a los atletas entrenar consistentemente sin lesiones.
        </p>
      </div>
      <div class="mission-card">
        <h3>Nuestra Visión</h3>
        <p>
          Ser la marca de referencia en recuperación deportiva en América Latina,
          reconocida por calidad, transparencia y resultados comprobados.
        </p>
      </div>
      <div class="mission-card">
        <h3>Nuestros Valores</h3>
        <ul>
          <li>🔬 Ciencia antes que marketing</li>
          <li>💼 Transparencia total</li>
          <li>🏆 Excelencia en cada lote</li>
          <li>💚 Propósito social</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- DIFERENCIADORES SECTION -->
  <section class="diferenciadores-section">
    <h2>Por Qué Confían en Nosotros</h2>
    <div class="diferenciadores-grid">
      {diferenciadores.map((item, index) => (
        <div class="diferenciador-card" key={index}>
          <div class="icon">{item.icon}</div>
          <h3>{item.title}</h3>
          <p>{item.description}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- TEAM SECTION -->
  <section class="team-section">
    <h2>El Equipo Detrás de Pure24</h2>
    <div class="team-grid">
      {teamMembers.map((member, index) => (
        <div class="team-card" key={index}>
          <div class="member-image">
            <img src={member.image} alt={member.name} loading="lazy" />
          </div>
          <h3>{member.name}</h3>
          <p class="role">{member.role}</p>
          <p class="bio">{member.bio}</p>
        </div>
      ))}
    </div>
  </section>

  <!-- STATS SECTION -->
  <section class="stats-section">
    <div class="stat">
      <h3>+10,000</h3>
      <p>Atletas satisfechos</p>
    </div>
    <div class="stat">
      <h3>5</h3>
      <p>Países en Sudamérica</p>
    </div>
    <div class="stat">
      <h3>100%</h3>
      <p>Certificaciones Obtenidas</p>
    </div>
    <div class="stat">
      <h3>24-36h</h3>
      <p>Recuperación Comprobada</p>
    </div>
  </section>

  <!-- SECTION 6: Social Proof (Testimonios) -->
  <section class="testimonials-section">
    <div class="container">
      <h2>Lo Que Dicen Nuestros Clientes</h2>
      <div class="testimonials-grid">
        {testimonials.map((testimonial) => (
          <QuoteCard
            name={testimonial.name}
            role={testimonial.role}
            text={testimonial.text}
            rating={testimonial.rating}
            image={testimonial.image}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- GUARANTEE SECTION -->
  <section class="guarantee-section">
    <div class="guarantee-content">
      <h2>30 Días de Garantía</h2>
      <p>
        Si no sientes la diferencia en tu recuperación en los primeros 30 días,
        te devolvemos el 100% de tu dinero. Sin preguntas.
      </p>
      <p class="subtitle-guarantee">
        +10,000 atletas han probado. 98% renueva. ¿Tú serás el próximo?
      </p>
      <a href="/productos" class="cta-button">Ver Nuestros Productos</a>
    </div>
  </section>

  <!-- CONTACT INVITE SECTION -->
  <section class="contact-invite">
    <h2>¿Preguntas?</h2>
    <p>Nuestro equipo está disponible para ayudarte</p>
    <a href="/contacto" class="cta-secondary">Contáctanos</a>
  </section>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .hero-about {
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    padding: 80px 20px;
    text-align: center;
    border-radius: 8px;
    margin: 40px 0;
  }

  .hero-content h1 {
    font-size: 3.5rem;
    margin-bottom: 20px;
    font-weight: 900;
  }

  .subtitle {
    font-size: 1.3rem;
    opacity: 0.95;
    margin-bottom: 20px;
    line-height: 1.7;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .description {
    font-size: 1.1rem;
    max-width: 600px;
    margin: 0 auto;
    opacity: 0.9;
  }

  /* Problem Section */
  .problem-section {
    padding: 60px 20px;
  }

  .problem-section h2 {
    font-size: 2.5rem;
    margin-bottom: 20px;
    color: var(--dark);
    text-align: center;
  }

  .section-intro {
    text-align: center;
    font-size: 1.1rem;
    color: var(--text-muted);
    margin-bottom: 40px;
  }

  .problem-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    margin-bottom: 30px;
  }

  .problem-card {
    background: linear-gradient(135deg, rgba(29, 78, 216, 0.1), rgba(6, 182, 212, 0.1));
    padding: 30px;
    border-radius: 8px;
    border-left: 4px solid var(--primary);
  }

  .problem-card h3 {
    color: var(--primary);
    margin-bottom: 15px;
    font-size: 1.3rem;
  }

  .problem-card p {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .problem-conclusion {
    text-align: center;
    font-size: 1.1rem;
    color: var(--dark);
    font-weight: 600;
    margin-top: 40px;
  }

  /* Timeline Section */
  .timeline-section {
    padding: 60px 20px;
  }

  .timeline-section h2 {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 40px;
    color: var(--dark);
  }

  .timeline {
    display: flex;
    flex-direction: column;
    gap: 30px;
    max-width: 800px;
    margin: 0 auto;
    position: relative;
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 20px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--primary), var(--secondary));
  }

  .timeline-item {
    display: flex;
    gap: 30px;
    position: relative;
    margin-left: 60px;
  }

  .year {
    position: absolute;
    left: -40px;
    top: 0;
    display: inline-block;
    background: var(--primary);
    color: white;
    padding: 8px 16px;
    border-radius: 20px;
    font-weight: 600;
    font-size: 0.85rem;
  }

  .content {
    flex: 1;
    background: white;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .content h3 {
    color: var(--dark);
    margin-bottom: 10px;
    font-size: 1.2rem;
  }

  .content p {
    color: var(--text-muted);
    line-height: 1.6;
    margin-bottom: 10px;
  }

  .content blockquote {
    font-style: italic;
    color: var(--primary);
    padding-left: 20px;
    border-left: 3px solid var(--primary);
    margin: 15px 0;
  }

  .content ul {
    margin: 15px 0;
    padding-left: 20px;
  }

  .content ul li {
    color: var(--text-muted);
    line-height: 1.6;
  }

  /* Testimonials Section */
  .testimonials-section {
    padding: 60px 20px;
    background: var(--light-bg);
    border-radius: 8px;
    margin: 40px 0;
  }

  .testimonials-section h2 {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 40px;
    color: var(--dark);
  }

  .testimonials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .mission-section {
    background: var(--light-bg);
    padding: 60px 20px;
    border-radius: 8px;
    margin: 40px 0;
  }

  .mission-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .mission-card {
    background: white;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .mission-card h3 {
    color: var(--primary);
    margin-bottom: 15px;
  }

  .mission-card ul {
    list-style: none;
    padding: 0;
  }

  .mission-card li {
    margin: 10px 0;
    color: var(--text-muted);
  }

  .diferenciadores-section {
    padding: 60px 20px;
  }

  .diferenciadores-section h2 {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 40px;
    color: var(--dark);
  }

  .diferenciadores-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .diferenciador-card {
    background: white;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .diferenciador-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.15);
  }

  .icon {
    font-size: 3rem;
    margin-bottom: 15px;
  }

  .diferenciador-card h3 {
    color: var(--dark);
    margin-bottom: 10px;
  }

  .diferenciador-card p {
    color: var(--text-muted);
    line-height: 1.6;
  }

  .team-section {
    padding: 60px 20px;
    background: var(--light-bg);
    border-radius: 8px;
    margin: 40px 0;
  }

  .team-section h2 {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 40px;
    color: var(--dark);
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    max-width: 1200px;
    margin: 0 auto;
  }

  .team-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
  }

  .team-card:hover {
    transform: translateY(-5px);
  }

  .member-image {
    width: 100%;
    height: 300px;
    overflow: hidden;
    background: var(--light-bg);
  }

  .member-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .team-card h3 {
    padding: 20px 20px 5px;
    color: var(--dark);
  }

  .role {
    padding: 0 20px;
    color: var(--primary);
    font-weight: 600;
    font-size: 0.9rem;
  }

  .bio {
    padding: 10px 20px 20px;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  .stats-section {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 30px;
    padding: 60px 20px;
    background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
    color: white;
    border-radius: 8px;
    margin: 40px 0;
  }

  .stat {
    text-align: center;
  }

  .stat h3 {
    font-size: 2.5rem;
    margin-bottom: 10px;
    font-weight: 900;
  }

  .stat p {
    opacity: 0.95;
  }

  .guarantee-section {
    background: white;
    border: 2px solid var(--primary);
    padding: 60px 20px;
    border-radius: 8px;
    text-align: center;
    margin: 40px 0;
  }

  .guarantee-section h2 {
    color: var(--primary);
    font-size: 2.5rem;
    margin-bottom: 20px;
  }

  .guarantee-section p {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 10px;
    line-height: 1.6;
  }

  .subtitle-guarantee {
    font-weight: 600;
    color: var(--dark);
    margin-bottom: 30px;
  }

  .cta-button {
    display: inline-block;
    background: linear-gradient(135deg, var(--primary), var(--secondary));
    color: white;
    padding: 15px 40px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    box-shadow: 0 4px 15px rgba(29, 78, 216, 0.3);
  }

  .cta-button:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(29, 78, 216, 0.4);
  }

  .contact-invite {
    text-align: center;
    padding: 60px 20px;
    background: var(--light-bg);
    border-radius: 8px;
    margin: 40px 0;
  }

  .contact-invite h2 {
    color: var(--dark);
    font-size: 2.5rem;
    margin-bottom: 10px;
  }

  .contact-invite p {
    color: var(--text-muted);
    font-size: 1.1rem;
    margin-bottom: 30px;
  }

  .cta-secondary {
    display: inline-block;
    border: 2px solid var(--primary);
    color: var(--primary);
    padding: 12px 35px;
    border-radius: 50px;
    text-decoration: none;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .cta-secondary:hover {
    background: var(--primary);
    color: white;
  }

  @media (max-width: 768px) {
    .hero-content h1 {
      font-size: 2.2rem;
    }

    .timeline::before {
      left: 10px;
    }

    .timeline-marker {
      min-width: 40px;
      height: 40px;
      font-size: 0.8rem;
    }

    .diferenciadores-section h2,
    .team-section h2,
    .guarantee-section h2,
    .contact-invite h2 {
      font-size: 1.8rem;
    }

    .stat h3 {
      font-size: 1.8rem;
    }
  }
</style>
