        competitorB: '$0.0320 CLP/mg',
        winner: 'pure24',
      },
    ],
  },
};

const data = comparisonData[category];
const columns = ['Característica', 'Pure24', 'Competidor A', 'Competidor B'];

function isWinner(winner: string | undefined, column: string): boolean {
  if (!winner) return false;
  if (column === 'Pure24') return winner === 'pure24';
  if (column === 'Competidor A') return winner === 'competitorA';
  if (column === 'Competidor B') return winner === 'competitorB';
  return false;
}
---

<section class="comparison-section">
  <div class="comparison-header">
    <h2>{data.title}</h2>
    <p class="subtitle">{data.subtitle}</p>
  </div>

  <div class="table-wrapper">
    <table class="comparison-table" role="grid" aria-label={data.title}>
      <thead>
        <tr>
          <th scope="col" class="feature-col">Característica</th>
          <th scope="col" class="pure24-col">Pure24</th>
          <th scope="col" class="competitor-col">Competidor A</th>
          <th scope="col" class="competitor-col">Competidor B</th>
        </tr>
      </thead>
      <tbody>
        {data.rows.map((row) => (
          <tr class="comparison-row">
            <td class="feature-col">
              <strong>{row.feature}</strong>
            </td>
            <td
              class={`pure24-col ${isWinner(row.winner, 'Pure24') ? 'winner' : ''}`}
            >
              {isWinner(row.winner, 'Pure24') && <span class="checkmark">✓</span>}
              {row.pure24}
            </td>
            <td
              class={`competitor-col ${isWinner(row.winner, 'Competidor A') ? 'winner' : ''}`}
            >
              {isWinner(row.winner, 'Competidor A') && <span class="checkmark">✓</span>}
              {row.competitorA}
            </td>
            <td
              class={`competitor-col ${isWinner(row.winner, 'Competidor B') ? 'winner' : ''}`}
            >
              {isWinner(row.winner, 'Competidor B') && <span class="checkmark">✓</span>}
              {row.competitorB}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="comparison-footer">
    <p class="disclaimer">
      * Datos técnicos basados en especificaciones del fabricante y estudios clínicos
      publicados. Comparativa actualizada a marzo 2026.
    </p>
    <a href="/data/productos.json" class="download-link" download>
      📥 Descargar datos técnicos completos (JSON)
    </a>
  </div>
</section>

<style>
  .comparison-section {
    width: 100%;
    margin: var(--spacing-xl) 0;
  }

  .comparison-header {
    text-align: center;
    margin-bottom: var(--spacing-lg);
  }

  .comparison-header h2 {
    color: var(--color-primary);
    margin-bottom: var(--spacing-sm);
    font-size: 1.75rem;
  }

  .subtitle {
    color: var(--color-text-secondary);
    font-size: 1.1rem;
    margin: 0;
  }

  .table-wrapper {
    overflow-x: auto;
    border-radius: var(--radius-lg);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .comparison-table {
    width: 100%;
    border-collapse: collapse;
    background: var(--color-white);
    font-size: 0.95rem;
  }

  .comparison-table thead {
    background: linear-gradient(135deg, var(--color-primary) 0%, #0d9488 100%);
    color: var(--color-white);
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .comparison-table th {
    padding: var(--spacing-md);
    text-align: left;
    font-weight: var(--font-weight-bold);
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .feature-col {
    width: 30%;
    min-width: 200px;
  }

  .pure24-col,
  .competitor-col {
    width: 23%;
    min-width: 150px;
  }

  .comparison-row {
    border-bottom: 1px solid var(--color-border);
    transition: background-color var(--transition-fast);
  }

  .comparison-row:hover {
    background-color: rgba(26, 188, 156, 0.05);
  }

  .comparison-row td {
    padding: var(--spacing-md);
    vertical-align: top;
  }

  .comparison-row .feature-col {
    font-weight: var(--font-weight-semibold);
    color: var(--color-text);
  }

  .comparison-row .pure24-col,
  .comparison-row .competitor-col {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.4;
  }

  .comparison-row .pure24-col.winner,
  .comparison-row .competitor-col.winner {
    background-color: rgba(76, 175, 80, 0.08);
    color: var(--color-success, #2e7d32);
    font-weight: var(--font-weight-semibold);
  }

  .checkmark {
    display: inline-block;
    margin-right: var(--spacing-xs);
    color: var(--color-success, #2e7d32);
    font-weight: bold;
    font-size: 1.2em;
  }

  .comparison-footer {
    text-align: center;
    margin-top: var(--spacing-lg);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border);
  }

  .disclaimer {
    color: var(--color-text-tertiary);
    font-size: 0.85rem;
    margin: 0 0 var(--spacing-md) 0;
    font-style: italic;
  }

  .download-link {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    background: linear-gradient(135deg, var(--color-primary) 0%, #0d9488 100%);
    color: var(--color-white);
    text-decoration: none;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: var(--font-weight-semibold);
    transition: all var(--transition-fast);
  }

  .download-link:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(26, 188, 156, 0.3);
  }

  @media (max-width: 768px) {
    .comparison-table {
      font-size: 0.85rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: var(--spacing-sm);
    }

    .feature-col {
      width: 35%;
      min-width: 140px;
    }

    .pure24-col,
    .competitor-col {
      width: 21.5%;
      min-width: 100px;
    }

    .comparison-header h2 {
      font-size: 1.4rem;
    }

    .subtitle {
      font-size: 0.95rem;
    }
  }

  @media (max-width: 480px) {
    .table-wrapper {
      border-radius: var(--radius-md);
    }

    .comparison-table {
      font-size: 0.75rem;
    }

    .comparison-table th,
    .comparison-table td {
      padding: 6px 8px;
    }

    .comparison-header h2 {
      font-size: 1.2rem;
    }

    .checkmark {
      font-size: 1rem;
    }
  }
</style>
