# ============== ENVIRONMENT ==============
NODE_ENV=development
PORT=3000

# ============== PAYLOAD CMS ==============
PAYLOAD_SECRET=tu_super_secret_seguro_cambiar_en_produccion
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# ============== DATABASE ==============
DATABASE_URI=postgresql://user:password@localhost:5432/pure24_db

# ============== MERCADO PAGO ==============
# Obtener en: https://www.mercadopago.com.ar/developers/es/docs/checkout-api/additional-content/your-integrations/credentials
MERCADOPAGO_ACCESS_TOKEN=APP_USR_1234567890123456789012345678901234567890
MERCADOPAGO_PUBLIC_KEY=APP_USR_PUBLIC_KEY
MERCADOPAGO_WEBHOOK_TOKEN=tu_webhook_token_opcional

# ============== EMAIL SERVICE ==============
# Elegir uno: smtp, sendgrid, resend
EMAIL_PROVIDER=smtp
EMAIL_FROM=noreply@pure24.cl

# --- SMTP (Gmail, Mailgun, etc.) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_email@gmail.com
SMTP_PASSWORD=app_password_no_contrasena_normal

# --- SendGrid (https://sendgrid.com) ---
# SENDGRID_API_KEY=SG.1234567890abcdefghijklmnopqrstuvwxyz

# --- Resend (https://resend.com) ---
# RESEND_API_KEY=re_1234567890abcdefghijklmnopqrstuvwxyz

# ============== FRONTEND ==============
PUBLIC_MERCADOPAGO_PUBLIC_KEY=APP_USR_PUBLIC_KEY
PUBLIC_API_URL=http://localhost:3000

# ============== LOGGING ==============
LOG_LEVEL=info
LOG_FORMAT=json

# ============== SECURITY ==============
CORS_ORIGIN=http://localhost:3001,http://localhost:3002
JWT_SECRET=tu_jwt_secret_seguro
