---
import type { Product } from '@shared/types';

interface Props {
  product: Product;
}

const { product } = Astro.props;
const hasDiscount = product.discountedPrice && product.discountedPrice < product.price;
const discount = hasDiscount ? Math.round(((product.price - product.discountedPrice!) / product.price) * 100) : 0;
---

<div class="product-card" data-product-id={product.id}>
  {/* Product Image */}
  <div class="product-image">
    {product.mainImage ? (
      <img
        src={product.mainImage.url}
        alt={product.mainImage.alt || product.name}
        loading="lazy"
        width="300"
        height="300"
      />
    ) : (
      <div class="placeholder">Sin imagen</div>
    )}
    {discount > 0 && (
      <div class="discount-badge">
        -{discount}%
      </div>
    )}
    {product.stock <= 10 && product.stock > 0 && (
      <div class="stock-badge">Pocas unidades</div>
    )}
    {product.stock === 0 && (
      <div class="out-of-stock">Agotado</div>
    )}
  </div>

  {/* Product Info */}
  <div class="product-info">
    {product.category && (
      <span class="category-label">{product.category.replace(/_/g, ' ')}</span>
    )}
    <a href={`/productos/${product.name.toLowerCase().replace(/\s+/g, '-')}`} class="product-name">
      {product.name}
    </a>

    {/* Description */}
    {product.description && (
      <p class="product-description">{product.description.substring(0, 80)}...</p>
    )}

    {/* Specifications */}
    {product.specifications && (
      <div class="specs">
        {product.specifications.servingSize && (
          <span class="spec-item">
            <strong>Porción:</strong> {product.specifications.servingSize}
          </span>
        )}
        {product.specifications.ingredientAmount && (
          <span class="spec-item">
            <strong>Ingrediente:</strong> {product.specifications.ingredientAmount}
          </span>
        )}
      </div>
    )}

    {/* Price */}
    <div class="price-section">
      {hasDiscount ? (
        <>
          <span class="original-price">${product.price.toLocaleString('es-CL')}</span>
          <span class="current-price">${product.discountedPrice!.toLocaleString('es-CL')}</span>
        </>
      ) : (
        <span class="current-price">${product.price.toLocaleString('es-CL')}</span>
      )}
    </div>

    {/* Tags */}
    {product.tags && product.tags.length > 0 && (
      <div class="tags">
        {product.tags.map((tag) => (
          <span class="tag">
            {typeof tag === 'string' ? tag : (tag as any).tag}
          </span>
        ))}
      </div>
    )}

    {/* Dosage Timing */}
    {product.dosage?.timing && (
      <div class="timing">
        <span class="timing-label">
          {product.dosage.timing.replace(/_/g, ' ').toLowerCase()}
        </span>
      </div>
    )}

    {/* CTA Button */}
    <button
      class="btn-add-cart"
      data-product-id={product.id}
      disabled={product.stock === 0}
    >
      {product.stock === 0 ? 'Agotado' : 'Agregar al carrito'}
    </button>
  </div>
</div>

<script>
  // Import cart store
  import { cartManager } from '../store/cart';

  document.querySelectorAll('.product-card').forEach((card) => {
    const btn = card.querySelector('.btn-add-cart') as HTMLButtonElement;
    if (!btn) return;

    btn.addEventListener('click', async (e) => {
      e.preventDefault();
      const productId = btn.getAttribute('data-product-id');
      if (!productId) return;

      // Extract product data from DOM
      const nameEl = card.querySelector('.product-name') as HTMLAnchorElement;
      const priceEl = card.querySelector('.current-price') as HTMLElement;
      const imageEl = card.querySelector('.product-image img') as HTMLImageElement;

      if (!nameEl || !priceEl) return;

      // Build product object with all required fields
      const product = {
        id: productId,
        name: nameEl.textContent || '',
        price: parseInt(priceEl.textContent!.replace(/[^\d]/g, ''), 10),
        stock: 100,
        category: 'products',
        mainImage: imageEl
          ? {
              url: imageEl.src,
              alt: imageEl.alt,
            }
          : undefined,
      } as any;

      // Add to cart using store
      cartManager.add(product, 1);

      // Visual feedback
      const originalText = btn.textContent;
      btn.textContent = '✓ Agregado';
      btn.classList.add('added');

      setTimeout(() => {
        btn.textContent = originalText;
        btn.classList.remove('added');
      }, 2000);
    });
  });
</script>

<style>
  .product-card {
    display: flex;
    flex-direction: column;
    height: 100%;
    background: white;
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid #e5e7eb;
    transition: all 0.3s ease;
  }

  .product-card:hover {
    border-color: #d1d5db;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.1);
    transform: translateY(-4px);
  }

  .product-image {
    position: relative;
    width: 100%;
    aspect-ratio: 1;
    background: #f3f4f6;
    overflow: hidden;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .product-card:hover .product-image img {
    transform: scale(1.05);
  }

  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #9ca3af;
    font-size: 14px;
  }

  .discount-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #dc2626;
    color: white;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
  }

  .stock-badge {
    position: absolute;
    bottom: 12px;
    left: 12px;
    background: #f59e0b;
    color: white;
    padding: 6px 12px;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
  }

  .out-of-stock {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.7);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    font-size: 16px;
    font-weight: 600;
  }

  .product-info {
    flex: 1;
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .category-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    color: #2563eb;
    letter-spacing: 0.5px;
  }

  .product-name {
    font-size: 15px;
    font-weight: 600;
    color: #1a1a1a;
    line-height: 1.4;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .product-card:hover .product-name {
    color: #2563eb;
  }

  .product-description {
    font-size: 13px;
    color: #6b7280;
    line-height: 1.4;
    margin: 0;
  }

  .specs {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 8px 0;
    font-size: 12px;
    color: #6b7280;
  }

  .spec-item {
    display: flex;
    gap: 4px;
  }

  .spec-item strong {
    color: #1a1a1a;
  }

  .price-section {
    display: flex;
    gap: 8px;
    align-items: center;
    padding: 8px 0;
  }

  .original-price {
    text-decoration: line-through;
    color: #9ca3af;
    font-size: 13px;
  }

  .current-price {
    font-size: 18px;
    font-weight: 700;
    color: #1a1a1a;
  }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
    padding: 4px 0;
  }

  .tag {
    display: inline-block;
    font-size: 11px;
    padding: 4px 8px;
    background: #f0f9ff;
    color: #0369a1;
    border-radius: 4px;
  }

  .timing {
    padding: 4px 0;
    font-size: 12px;
    color: #7c3aed;
    font-weight: 500;
  }

  .btn-add-cart {
    margin-top: auto;
    padding: 10px 16px;
    background: #2563eb;
    color: white;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .btn-add-cart:hover:not(:disabled) {
    background: #1d4ed8;
    transform: translateY(-2px);
  }

  .btn-add-cart:disabled {
    background: #d1d5db;
    cursor: not-allowed;
  }

  .btn-add-cart.added {
    background: #10b981;
  }

  @media (max-width: 640px) {
    .product-info {
      padding: 12px;
      gap: 6px;
    }

    .product-name {
      font-size: 14px;
    }

    .current-price {
      font-size: 16px;
    }
  }
</style>
