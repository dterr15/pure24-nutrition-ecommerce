        winner: 'pure24',
      },
      {
        feature: 'Antioxidantes adicionales',
        pure24: 'E (tocoferol) + Selenio',
        competitorA: 'Solo vitamina C',
        competitorB: 'Solo vitamina C + Vitamina E',
        winner: 'pure24',
      },
      {
        feature: 'Reducción de DOMS',
        pure24: '35-40% menos dolor muscular',
        competitorA: 'Efecto limitado (15%)',
        competitorB: 'Sin estudio (10%)',
        winner: 'pure24',
      },
      {
        feature: 'Estudios de eficacia',
        pure24: '5 estudios clínicos (PubMed)',
        competitorA: '1 estudio (2015)',
        competitorB: 'Ninguno publicado',
        winner: 'pure24',
      },
      {
        feature: 'Precio por dosis (mg)',
        pure24: '$0.0225 CLP/mg',
