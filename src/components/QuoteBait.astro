---
// src/components/QuoteBait.astro
// Quote-Bait: Micro-respuestas formateadas para citación directa por IA
// Usado por ChatGPT, Perplexity, Google AI Overviews

export interface QuoteBaitItem {
  question: string;        // ¿Cuál es el beneficio principal?
  points: {
    term: string;          // término técnico
    definition: string;    // definición (<50 palabras total)
  }[];
}

interface Props {
  items: QuoteBaitItem[];
  title?: string;
  section_id?: string;
}

const {
  items,
  title = "Beneficios y Especificaciones",
  section_id = "quote-bait"
} = Astro.props;

// Validar formato
items.forEach((item, idx) => {
  const totalWords = item.points
    .reduce((sum, p) => sum + p.definition.split(/\s+/).length, 0);

  if (totalWords > 50) {
    console.warn(`QuoteBait [${idx}]: ${totalWords} palabras (máx 50)`);
  }

  if (item.points.length > 3) {
    console.warn(`QuoteBait [${idx}]: ${item.points.length} puntos (máx 3)`);
  }
});
---

<section id={section_id} class="quote-bait-section">
  <div class="container">
    <h2>{title}</h2>

    <div class="quote-bait-list">
      {items.map((item) => (
        <article class="quote-bait-item">
          <h3 class="quote-bait-question">{item.question}</h3>

          <ul class="quote-bait-points">
            {item.points.map((point) => (
              <li class="quote-bait-point">
                <strong class="quote-term">{point.term}:</strong>
                <span class="quote-definition">{point.definition}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .quote-bait-section {
    padding: var(--section-padding-desktop);
    background-color: var(--color-background);
  }

  .quote-bait-section h2 {
    text-align: center;
    margin-bottom: var(--space-3xl);
    font-size: var(--font-size-2xl);
    color: var(--color-neutral-dark);
  }

  .quote-bait-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-2xl);
    max-width: 1200px;
    margin: 0 auto;
  }

  .quote-bait-item {
    padding: var(--space-2xl);
    background-color: var(--color-white);
    border-radius: var(--radius-lg);
    border-left: 4px solid var(--color-primary);
    box-shadow: var(--shadow-md);
    transition: box-shadow var(--transition-normal),
                transform var(--transition-normal);
  }

  .quote-bait-item:hover {
    box-shadow: var(--shadow-lg);
    transform: translateY(-2px);
  }

  .quote-bait-question {
    font-size: var(--font-size-lg);
    font-weight: 700;
    color: var(--color-neutral-dark);
    margin-bottom: var(--space-lg);
    line-height: var(--line-height-tight);
  }

  .quote-bait-points {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .quote-bait-point {
    padding: var(--space-md) 0;
    color: var(--color-neutral-mid);
    line-height: var(--line-height-relaxed);
    font-size: var(--font-size-sm);
  }

  .quote-bait-point:not(:last-child) {
    border-bottom: 1px solid var(--color-neutral-light);
  }

  .quote-term {
    color: var(--color-primary);
    font-weight: 700;
    display: inline;
  }

  .quote-definition {
    display: inline;
    color: var(--color-neutral-dark);
  }

  /* Optimización para copia por IA */
  .quote-bait-item {
    user-select: all;
    -webkit-user-select: all;
  }

  .quote-bait-question {
    user-select: text;
  }

  @media (max-width: 768px) {
    .quote-bait-section {
      padding: var(--section-padding-mobile);
    }

    .quote-bait-list {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .quote-bait-item {
      padding: var(--space-xl);
    }
  }
</style>
